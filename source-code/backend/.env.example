# Backend environment template   copy to `.env` and fill in real values.
# Do NOT commit the real .env (it is git-ignored). On the server, place the
# production .env at ~/SVWR-CFE/source-code/backend/.env (the rsync deploy excludes it).

# ── Server ──
NODE_ENV=production
PORT=3001

# ── CORS & frontend (use your real domain/IP, NOT localhost, in production) ──
FRONTEND_URL=http://16.192.28.113:3000
CORS_ORIGIN=http://16.192.28.113:3000

# ── Database (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=SVWR_CFE_DB_OG
DB_USER=postgres
DB_PASSWORD=__SET_ME__
# Optional single-URL form used by some tooling:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── JWT ──
JWT_SECRET=__SET_A_LONG_RANDOM_STRING__
JWT_EXPIRE=30d

# ── Email (SMTP) ──
EMAIL_FROM=notify@your-domain
EMAIL_FROM_NAME=Your Brand
EMAIL_REPLY_TO=support@your-domain
SUPPORT_EMAIL=support@your-domain
EMAIL_COMPANY_ADDRESS=Your Company, City, Country
EMAIL_UNSUBSCRIBE_URL=
SMTP_HOST=premium267.web-hosting.com
SMTP_PORT=587
SMTP_USER=notify@your-domain
SMTP_PASS=__SET_ME__

# ── Redis (optional) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── File uploads ──
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# ── ML / AI services ──
COMMUNICATION_API_URL=http://localhost:8091
AI_SERVICE_URL=http://localhost:5000



